# =============================================================
# 사내 폐쇄망 LightRAG 설정 파일
# 이 파일을 .env.onprem 으로 복사한 뒤 값을 채우세요.
# =============================================================

# --- LLM API ---
ONPREM_LLM_BASE_URL=http://apigw-stg.shyum.net:8000/gpt-oss/1/gpt-oss-120b/v1
ONPREM_LLM_MODEL=openai/gpt-oss-120b
ONPREM_LLM_CREDENTIAL_KEY=여기에_DS_API_HUB_credential_key
ONPREM_SEND_SYSTEM_NAME=test_api_1
ONPREM_USER_ID=여기에_KNOX_ID

# --- 임베딩 API (별도 서버가 있을 경우만 수정) ---
# ONPREM_EMBED_BASE_URL=http://apigw-stg.shyum.net:8000/embedding/1/v1
# ONPREM_EMBED_MODEL=text-embedding-3-small
# ONPREM_EMBED_DIM=1536
# ONPREM_EMBED_CREDENTIAL_KEY=임베딩용_credential_key

# --- Reranker API ---
ONPREM_RERANK_BASE_URL=http://apigw-stg.shyum.net:8000/reranker/1/v2/rerank
ONPREM_RERANK_MODEL=bge-reranker-v2-m3-ko
ONPREM_RERANK_CREDENTIAL_KEY=여기에_reranker_credential_key
ONPREM_RERANK_TOP_N=5
